<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Planes de Promoción</title>
  <style>
    body {
  font-family: Arial, sans-serif;
  background: #f2f2f2;
  margin: 0;
}

.pricing {
  text-align: center;
  padding: 40px 20px;
}

h1 {
  font-size: 42px;
  color: #555;
}

.subtitle {
  color: #777;
  margin-bottom: 30px;
}
.pricing-table {
  width: 90%;
  max-width: 1100px;
  margin: auto;
  border-collapse: collapse;
  background: white;
}

th, td {
  padding: 15px;
  border: 1px solid #eee;
  text-align: center;
  color: #555;
}
th {
  color: white;
  font-weight: bold;
}

th.features {
  background: #ddd;
  color: #444;
}

th.empresa {
  background: #5a6169;
}

th.avance {
  background: #e14b61;
}

th.entrante {
  background: #6cc36c;
}
td:first-child {
  text-align: left;
}
.price {
  font-size: 22px;
  font-weight: bold;
}
.red {
  color: #e14b61;
}
.green {
  color: #6cc36c;
}
button {
  padding: 8px 18px;
  border: 1px solid #aaa;
  background: transparent;
  cursor: pointer;
}

button.active {
  background: #e14b61;
  color: white;
  border: none;
}
.buttons td {
  padding: 20px;
}
  </style>
</head>
<body>

<section class="pricing">
  <h1>Planes de Promoción</h1>
  <p class="subtitle">
    Lorem ipsum dolor sit amet consectetur adipisicing elit. Odio, eum?
  </p>

  <table class="pricing-table">
    <thead>
      <tr>
        <th class="features">COMPARAR TODOS LOS PLANES</th>
        <th class="empresa">EMPRESA</th>
        <th class="avance">AVANCE</th>
        <th class="entrante">ENTRANTE</th>
      </tr>
    </thead>

    <tbody>
      <tr>
        <td>Siguiente mes</td>
        <td class="price">$ 900</td>
        <td class="price red">$ 700</td>
        <td class="price green">$ 300</td>
      </tr>

      <tr>
        <td>Plazo de entrega</td>
        <td>3-6 meses</td>
        <td>3-6 meses</td>
        <td>3-6 meses</td>
      </tr>

      <tr>
        <td>Soporte 24/7</td>
        <td>✔</td>
        <td>✔</td>
        <td>-</td>
      </tr>

      <tr>
        <td>Certificado</td>
        <td>✔</td>
        <td>✔</td>
        <td>-</td>
      </tr>

      <tr>
        <td>Clasificación de palabras clave garantizadas por Google</td>
        <td>28</td>
        <td>20</td>
        <td>18</td>
      </tr>

      <tr class="buttons">
        <td></td>
        <td><button>Elegir Plan</button></td>
        <td><button class="active">Elegir Plan</button></td>
        <td><button>Elegir Plan</button></td>
      </tr>
    </tbody>
  </table>

</section>

</body>
</html>
